<Application x:Class="AeroControl.Setup.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="Surface" Color="#F3F6F2" />
        <SolidColorBrush x:Key="Ink" Color="#17211E" />
        <SolidColorBrush x:Key="Muted" Color="#60706A" />
        <SolidColorBrush x:Key="Accent" Color="#0B7452" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Application.Resources>
</Application>
