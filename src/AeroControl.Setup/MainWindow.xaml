<Window x:Class="AeroControl.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AeroControl Setup"
        Width="640"
        Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Surface}"
        FontFamily="Segoe UI Variable Text"
        Loaded="Window_Loaded">
        <Grid x:Name="RootGrid" Background="{StaticResource Surface}">
            <Grid Margin="34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="AERO CONTROL"
                       FontFamily="Bahnschrift"
                       FontSize="27"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Ink}" />
            <TextBlock Margin="0,5,0,0"
                       Text="Per-user installation"
                       Foreground="{StaticResource Muted}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,25,0,0"
                Padding="18"
                Background="White"
                BorderBrush="#D9E1DC"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Install location" FontWeight="SemiBold" />
                <TextBox x:Name="InstallPathTextBox"
                         Margin="0,8,0,0"
                         IsReadOnly="True" />
                <TextBlock Margin="0,8,0,0"
                           Text="No administrator access is required. Files are installed for the current Windows user only."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Muted}" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,22,0,0">
            <CheckBox x:Name="StartupCheckBox"
                      Content="Launch AeroControl when I sign in" />
            <CheckBox x:Name="LaunchCheckBox"
                      Margin="0,12,0,0"
                      IsChecked="True"
                      Content="Launch AeroControl after installation" />
        </StackPanel>

        <Border Grid.Row="3"
                Margin="0,22,0,0"
                Padding="14"
                Background="#FFF3D9"
                BorderBrush="#F0B24A"
                BorderThickness="1"
                CornerRadius="4">
            <TextBlock Text="AeroControl is unofficial hardware-control software provided AS IS. Read DISCLAIMER.md before use. This setup executable is currently unsigned and may show Windows publisher warnings."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource Ink}" />
        </Border>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Margin="0,22,0,0"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource Muted}" />

        <Grid Grid.Row="5" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Margin="0,0,10,0"
                    Content="Remove installation"
                    Click="RemoveButton_Click" />
            <Button Grid.Column="2"
                    Padding="22,10"
                    Background="{StaticResource Accent}"
                    Foreground="White"
                    Content="Install"
                    Click="InstallButton_Click" />
        </Grid>
            </Grid>
        </Grid>
</Window>
