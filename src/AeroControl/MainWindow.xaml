<Window x:Class="AeroControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AeroControl.Controls"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="AeroControl"
        Width="1180"
        Height="820"
        MinWidth="980"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable Text"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    <Grid x:Name="RootGrid" Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        VerticalAlignment="Center"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="4">
                    <TextBlock Text="AC"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Bahnschrift"
                               FontWeight="Bold"
                               FontSize="15"
                               Foreground="White" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="AERO CONTROL"
                               FontFamily="Bahnschrift"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Unofficial Gigabyte laptop utility"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="#AFC0B9" />
                </StackPanel>

                <Border Grid.Column="3"
                        VerticalAlignment="Center"
                        Padding="12,7"
                        BorderBrush="#43625A"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding EnvironmentLabel}"
                                   FontFamily="Bahnschrift"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs"
                Grid.Row="1"
                SelectedIndex="0"
            SelectionChanged="MainTabs_SelectionChanged"
                Style="{StaticResource NavigationTabControlStyle}">
            <TabItem Header="Cooling" Style="{StaticResource NavigationTabItemStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32,26,32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Cooling dashboard"
                                   FontFamily="Bahnschrift"
                                   FontSize="29"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Margin="0,5,0,0"
                                   Text="{Binding DeviceName}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding DeviceDetails}"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedInkBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding ConnectionState}"
                                   HorizontalAlignment="Right"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding LastUpdated}"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Right"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedInkBrush}" />
                    </StackPanel>
                </Grid>

                <primitives:UniformGrid Grid.Row="1"
                                        Margin="-6,20,-6,0"
                                        Rows="1"
                                        Columns="4">
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource DangerBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="CPU TEMPERATURE"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding CpuTemperature}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Package sensor"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource CoolBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="GPU TEMPERATURE"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding GpuTemperature}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Discrete GPU sensor"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="FAN 1"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding Fan1Speed}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="25"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="CPU cooling path"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource WarningBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="FAN 2"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding Fan2Speed}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="25"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="GPU cooling path"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </primitives:UniformGrid>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Fan control"
                                               FontFamily="Bahnschrift"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Firmware automatic mode or fixed duty for both cooling paths"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding FanMode}"
                                               HorizontalAlignment="Right"
                                               FontFamily="Bahnschrift"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="{Binding FanDuty}"
                                               Margin="0,3,0,0"
                                               HorizontalAlignment="Right"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Margin="0,22,0,8"
                                       Text="PRESETS"
                                       FontFamily="Bahnschrift"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedInkBrush}" />

                            <primitives:UniformGrid Grid.Row="2" Columns="4">
                                <Button Margin="0,0,8,0"
                                        Content="Automatic"
                                        Tag="auto"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                                <Button Margin="0,0,8,0"
                                        Content="70%"
                                        Tag="70"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                                <Button Margin="0,0,8,0"
                                        Content="80%"
                                        Tag="80"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                                <Button Content="100%"
                                        Tag="100"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                            </primitives:UniformGrid>

                            <Grid Grid.Row="3" Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="Custom"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <Slider Grid.Column="1"
                                        Margin="16,0"
                                    AutomationProperties.Name="Custom fixed fan duty percentage"
                                        Minimum="30"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding CustomFanPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2"
                                           Width="46"
                                           VerticalAlignment="Center"
                                           Text="{Binding CustomFanLabel}"
                                           FontFamily="Bahnschrift"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <Button Grid.Column="3"
                                        Content="Apply"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="CustomFanButton_Click" />
                            </Grid>

                            <CheckBox x:Name="RestoreAutomaticOnExitCheckBox"
                                      Grid.Row="4"
                                      Margin="0,24,0,0"
                                      IsChecked="{Binding Settings.RestoreAutomaticOnExit}"
                                      Content="Restore automatic fan control when AeroControl exits"
                                      FontSize="12"
                                      Foreground="{StaticResource MutedInkBrush}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Device status"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />

                            <Grid Grid.Row="1" Margin="0,19,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fan health" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FanHealth}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,13,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Firmware methods" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           MaxWidth="230"
                                           Text="{Binding CapabilitySummary}"
                                           TextAlignment="Right"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                            </Grid>
                            <StackPanel Grid.Row="3" Margin="0,13,0,0">
                                <TextBlock Text="Access" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding PrivilegeLabel}"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock x:Name="RiskStatusText"
                                           Margin="0,4,0,0"
                                           Text="Firmware writes locked"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>

                            <Grid Grid.Row="5" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Margin="0,0,5,0"
                                        Content="Refresh"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="RefreshButton_Click" />
                                <Button x:Name="AccessButton"
                                        Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Content="Safety notice"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="AccessButton_Click" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="16,12"
                        Background="#E8EFEB"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{StaticResource InkBrush}" />
                        <Button x:Name="RestartAdminButton"
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                Content="Restart as administrator"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RestartAdminButton_Click" />
                    </Grid>
                </Border>
            </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Battery" Style="{StaticResource NavigationTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="32,26,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Battery health"
                                           FontFamily="Bahnschrift"
                                           FontSize="29"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Margin="0,5,0,0"
                                           Text="{Binding BatteryName}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="Standard Windows power telemetry; no firmware writes"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding BatteryConnectionState}"
                                           HorizontalAlignment="Right"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding BatteryLastUpdated}"
                                           HorizontalAlignment="Right"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>

                        <primitives:UniformGrid Grid.Row="1"
                                                Margin="-6,20,-6,0"
                                                Rows="1"
                                                Columns="4">
                            <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CURRENT CHARGE"
                                               FontFamily="Bahnschrift"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding BatteryCharge}"
                                               FontFamily="Bahnschrift"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <ProgressBar Margin="0,12,0,0"
                                                 AutomationProperties.Name="Current battery charge"
                                                 Value="{Binding BatteryChargeValue, Mode=OneWay}"
                                                 Style="{StaticResource BatteryProgressStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding BatteryState}"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CAPACITY RETENTION"
                                               FontFamily="Bahnschrift"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding BatteryRetention}"
                                               FontFamily="Bahnschrift"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <ProgressBar Margin="0,12,0,0"
                                                 AutomationProperties.Name="Battery capacity retention"
                                                 Value="{Binding BatteryRetentionValue, Mode=OneWay}"
                                                 Foreground="{StaticResource CoolBrush}"
                                                 Style="{StaticResource BatteryProgressStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Full charge versus design"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="FULL CHARGE"
                                               FontFamily="Bahnschrift"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding BatteryFullCapacity}"
                                               FontFamily="Bahnschrift"
                                               FontSize="25"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Design capacity"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Text="{Binding BatteryDesignCapacity}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="CYCLE COUNT"
                                               FontFamily="Bahnschrift"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding BatteryCycleCount}"
                                               FontFamily="Bahnschrift"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Reported by Windows"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                            </Border>
                        </primitives:UniformGrid>

                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Power status"
                                               FontFamily="Bahnschrift"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <Grid Grid.Row="1" Margin="0,20,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Source" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryPowerSource}" FontWeight="SemiBold" />
                                    </Grid>
                                    <Grid Grid.Row="2" Margin="0,13,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="State" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryState}" FontWeight="SemiBold" />
                                    </Grid>
                                    <Grid Grid.Row="3" Margin="0,13,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Voltage" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryVoltage}" FontWeight="SemiBold" />
                                    </Grid>
                                    <Grid Grid.Row="4" Margin="0,13,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Power flow" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryPowerFlow}" FontWeight="SemiBold" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Capacity detail"
                                               FontFamily="Bahnschrift"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <Grid Grid.Row="1" Margin="0,20,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Remaining" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryRemaining}" FontWeight="SemiBold" />
                                    </Grid>
                                    <Grid Grid.Row="2" Margin="0,13,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Full charge capacity" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryFullCapacity}" FontWeight="SemiBold" />
                                    </Grid>
                                    <Grid Grid.Row="3" Margin="0,13,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Design capacity" Foreground="{StaticResource MutedInkBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding BatteryDesignCapacity}" FontWeight="SemiBold" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Margin="0,18,0,0"
                                Padding="16,12"
                                Background="#E8EFEB"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBlock Text="{Binding BatteryStatusMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{StaticResource InkBrush}" />
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Monitor" Style="{StaticResource NavigationTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="32,26,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Session monitor"
                                           FontFamily="Bahnschrift"
                                           FontSize="29"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Margin="0,5,0,0"
                                           Text="{Binding MonitorSummary}"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Export CSV"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ExportHistoryButton_Click" />
                        </Grid>

                        <Border Grid.Row="1" Margin="0,20,0,0" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Temperature history"
                                               FontFamily="Bahnschrift"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="CPU  /  GPU" Foreground="{StaticResource MutedInkBrush}" />
                                </Grid>
                                <controls:TelemetryChart Height="180"
                                                         Margin="0,14,0,0"
                                                         AutomationProperties.Name="CPU and GPU temperature history"
                                                         Minimum="30"
                                                         Maximum="105"
                                                         Series1="{Binding CpuHistory}"
                                                         Series2="{Binding GpuHistory}"
                                                         Series1Brush="{StaticResource DangerBrush}"
                                                         Series2Brush="{StaticResource CoolBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Fan speed history"
                                               FontFamily="Bahnschrift"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <controls:TelemetryChart Height="170"
                                                             Margin="0,14,0,0"
                                                             AutomationProperties.Name="Fan 1 and Fan 2 speed history"
                                                             Minimum="0"
                                                             Maximum="6500"
                                                             Series1="{Binding Fan1History}"
                                                             Series2="{Binding Fan2History}"
                                                             Series1Brush="{StaticResource AccentBrush}"
                                                             Series2Brush="{StaticResource WarningBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Battery history (charge % / absolute power W)"
                                               FontFamily="Bahnschrift"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <controls:TelemetryChart Height="170"
                                                             Margin="0,14,0,0"
                                                             AutomationProperties.Name="Battery charge and power history"
                                                             Minimum="0"
                                                             Maximum="100"
                                                             Series1="{Binding BatteryHistory}"
                                                             Series2="{Binding PowerHistory}"
                                                             Series1Brush="{StaticResource AccentBrush}"
                                                             Series2Brush="{StaticResource CoolBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Margin="0,18,0,0"
                                Padding="16,12"
                                Background="#E8EFEB"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBlock Text="History is held in memory for this session only. Export is explicit and contains telemetry columns only."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource InkBrush}" />
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Diagnostics" Style="{StaticResource NavigationTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="32,26,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Diagnostics"
                                           FontFamily="Bahnschrift"
                                           FontSize="29"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,5,0,0"
                                           Text="Sanitized compatibility data; no serials or personal identifiers"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Margin="0,0,10,0"
                                    Content="Refresh"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="RefreshDiagnosticsButton_Click" />
                            <Button Grid.Column="2"
                                    Content="Export JSON"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ExportDiagnosticsButton_Click" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Device and firmware" FontFamily="Bahnschrift" FontSize="19" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,14,0,0" Text="{Binding DiagnosticsDevice}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0" Text="Known competing tools" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding DiagnosticsConflicts}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Software and trust" FontFamily="Bahnschrift" FontSize="19" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,14,0,0" Text="{Binding DiagnosticsSoftware}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0" Text="Signature and hash" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding DiagnosticsSignature}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Firmware read methods" FontFamily="Bahnschrift" FontSize="19" FontWeight="SemiBold" />
                                    <TextBox Margin="0,12,0,0"
                                             Height="150"
                                             Text="{Binding DiagnosticsReadMethods, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Firmware write methods" FontFamily="Bahnschrift" FontSize="19" FontWeight="SemiBold" />
                                    <TextBox Margin="0,12,0,0"
                                             Height="150"
                                             Text="{Binding DiagnosticsWriteMethods, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3" Margin="0,18,0,0" Padding="16,12" Background="#E8EFEB" CornerRadius="4">
                            <TextBlock Text="{Binding DiagnosticsStatus}" TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profiles" Style="{StaticResource NavigationTabItemStyle}">
                <Grid Margin="32,26,32,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Fan profiles" FontFamily="Bahnschrift" FontSize="29" FontWeight="SemiBold" />
                        <TextBlock Margin="0,5,0,0"
                                   Text="Saved names reuse the existing verified fixed-duty path; no new firmware commands"
                                   Foreground="{StaticResource MutedInkBrush}" />
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ListBox x:Name="ProfilesList"
                                         ItemsSource="{Binding Settings.FanProfiles}"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6" MinHeight="38">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{Binding Percent, StringFormat={}{0}%}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                        <Button Margin="0,0,5,0"
                                            Content="Apply selected"
                                            IsEnabled="{Binding CanControlFans}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="ApplyProfileButton_Click" />
                                    <Button Grid.Column="1" Margin="5,0,0,0" Content="Delete selected" Style="{StaticResource SecondaryButtonStyle}" Click="DeleteProfileButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Create profile" FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Margin="0,18,0,5" Text="Name" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBox x:Name="ProfileNameTextBox" MaxLength="32" />
                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Fixed duty" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock x:Name="ProfilePercentLabel" Grid.Column="1" Text="80%" FontWeight="SemiBold" />
                                </Grid>
                                <Slider x:Name="ProfilePercentSlider"
                                        Margin="0,8,0,0"
                                        AutomationProperties.Name="New profile fixed fan duty percentage"
                                        Minimum="30"
                                        Maximum="100"
                                        Value="80"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ProfilePercentSlider_ValueChanged" />
                                <Button Margin="0,24,0,0" Content="Add profile" Style="{StaticResource PrimaryButtonStyle}" Click="AddProfileButton_Click" />
                                <TextBlock x:Name="ProfilesStatusText" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings" Style="{StaticResource NavigationTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="32,26,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="Settings" FontFamily="Bahnschrift" FontSize="29" FontWeight="SemiBold" />
                            <TextBlock Margin="0,5,0,0" Text="Per-user, reversible Windows and notification preferences" Foreground="{StaticResource MutedInkBrush}" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Windows and navigation" FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold" />
                                    <CheckBox Margin="0,18,0,0" Content="Launch AeroControl when I sign in" IsChecked="{Binding Settings.StartWithWindows}" />
                                    <CheckBox Margin="0,12,0,0" Content="Minimize to the notification area" IsChecked="{Binding Settings.MinimizeToTray}" />
                                    <CheckBox Margin="0,12,0,0" Content="Remember the last selected view" IsChecked="{Binding Settings.RememberLastView}" />
                                    <CheckBox Margin="0,12,0,0" Content="Restore automatic fan control on exit" IsChecked="{Binding Settings.RestoreAutomaticOnExit}" />
                                    <TextBlock Margin="0,22,0,5" Text="Refresh interval (seconds)" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBox Text="{Binding Settings.RefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,16,0,5" Text="Monitor history window (5, 15, 30, or 60 minutes)" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBox Text="{Binding Settings.HistoryMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Notifications" FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold" />
                                    <CheckBox Margin="0,18,0,0" Content="Enable local temperature and fan alerts" IsChecked="{Binding Settings.EnableNotifications}" />
                                    <CheckBox Margin="0,12,0,0" Content="Enable fixed-mode fan stall alerts" IsChecked="{Binding Settings.EnableFanStallAlert}" />
                                    <TextBlock Margin="0,22,0,5" Text="CPU alert threshold (70-100 C)" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBox Text="{Binding Settings.CpuAlertCelsius, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,16,0,5" Text="GPU alert threshold (65-100 C)" Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBox Text="{Binding Settings.GpuAlertCelsius, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,22,0,0"
                                               Text="Alerts require three consecutive abnormal samples and never change hardware settings."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" Margin="0,18,0,0" Padding="16,12" Background="#E8EFEB" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SettingsStatusText" Text="Settings are stored under LocalAppData for this Windows user." VerticalAlignment="Center" TextWrapping="Wrap" />
                                <Button Grid.Column="1" Margin="16,0,0,0" Content="Save settings" Style="{StaticResource PrimaryButtonStyle}" Click="SaveSettingsButton_Click" />
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
