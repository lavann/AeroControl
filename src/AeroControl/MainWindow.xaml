<Window x:Class="AeroControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="AeroControl"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable Text"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid x:Name="RootGrid" Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        VerticalAlignment="Center"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="4">
                    <TextBlock Text="AC"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Bahnschrift"
                               FontWeight="Bold"
                               FontSize="15"
                               Foreground="White" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="13,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="AERO CONTROL"
                               FontFamily="Bahnschrift"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Unofficial Gigabyte laptop utility"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="#AFC0B9" />
                </StackPanel>

                <Border Grid.Column="3"
                        VerticalAlignment="Center"
                        Padding="12,7"
                        BorderBrush="#43625A"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding EnvironmentLabel}"
                                   FontFamily="Bahnschrift"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32,26,32,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Cooling dashboard"
                                   FontFamily="Bahnschrift"
                                   FontSize="29"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Margin="0,5,0,0"
                                   Text="{Binding DeviceName}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding DeviceDetails}"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedInkBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding ConnectionState}"
                                   HorizontalAlignment="Right"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding LastUpdated}"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Right"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedInkBrush}" />
                    </StackPanel>
                </Grid>

                <primitives:UniformGrid Grid.Row="1"
                                        Margin="-6,20,-6,0"
                                        Rows="1"
                                        Columns="4">
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource DangerBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="CPU TEMPERATURE"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding CpuTemperature}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Package sensor"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource CoolBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="GPU TEMPERATURE"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding GpuTemperature}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="Discrete GPU sensor"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="FAN 1"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding Fan1Speed}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="25"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="CPU cooling path"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="6" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource WarningBrush}" CornerRadius="2" />
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="FAN 2"
                                           FontFamily="Bahnschrift"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Text="{Binding Fan2Speed}"
                                           Margin="0,10,0,0"
                                           FontFamily="Bahnschrift"
                                           FontSize="25"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="GPU cooling path"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </primitives:UniformGrid>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,9,0" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Fan control"
                                               FontFamily="Bahnschrift"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Firmware automatic mode or fixed duty for both cooling paths"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding FanMode}"
                                               HorizontalAlignment="Right"
                                               FontFamily="Bahnschrift"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="{Binding FanDuty}"
                                               Margin="0,3,0,0"
                                               HorizontalAlignment="Right"
                                               FontSize="12"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Margin="0,22,0,8"
                                       Text="PRESETS"
                                       FontFamily="Bahnschrift"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedInkBrush}" />

                            <primitives:UniformGrid Grid.Row="2" Columns="4">
                                <Button Margin="0,0,8,0"
                                        Content="Automatic"
                                        Tag="auto"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                                <Button Margin="0,0,8,0"
                                        Content="70%"
                                        Tag="70"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                                <Button Margin="0,0,8,0"
                                        Content="80%"
                                        Tag="80"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                                <Button Content="100%"
                                        Tag="100"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="FanPresetButton_Click" />
                            </primitives:UniformGrid>

                            <Grid Grid.Row="3" Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="Custom"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <Slider Grid.Column="1"
                                        Margin="16,0"
                                        Minimum="30"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding CustomFanPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="2"
                                           Width="46"
                                           VerticalAlignment="Center"
                                           Text="{Binding CustomFanLabel}"
                                           FontFamily="Bahnschrift"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <Button Grid.Column="3"
                                        Content="Apply"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        IsEnabled="{Binding CanControlFans}"
                                        Click="CustomFanButton_Click" />
                            </Grid>

                            <CheckBox x:Name="RestoreAutomaticOnExitCheckBox"
                                      Grid.Row="4"
                                      Margin="0,24,0,0"
                                      IsChecked="True"
                                      Content="Restore automatic fan control when AeroControl exits"
                                      FontSize="12"
                                      Foreground="{StaticResource MutedInkBrush}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Device status"
                                       FontFamily="Bahnschrift"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />

                            <Grid Grid.Row="1" Margin="0,19,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fan health" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FanHealth}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,13,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Firmware methods" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Grid.Column="1"
                                           MaxWidth="230"
                                           Text="{Binding CapabilitySummary}"
                                           TextAlignment="Right"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                            </Grid>
                            <StackPanel Grid.Row="3" Margin="0,13,0,0">
                                <TextBlock Text="Access" Foreground="{StaticResource MutedInkBrush}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding PrivilegeLabel}"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock x:Name="RiskStatusText"
                                           Margin="0,4,0,0"
                                           Text="Firmware writes locked"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedInkBrush}" />
                            </StackPanel>

                            <Grid Grid.Row="5" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Margin="0,0,5,0"
                                        Content="Refresh"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="RefreshButton_Click" />
                                <Button x:Name="AccessButton"
                                        Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Content="Safety notice"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="AccessButton_Click" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="16,12"
                        Background="#E8EFEB"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{StaticResource InkBrush}" />
                        <Button x:Name="RestartAdminButton"
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                Content="Restart as administrator"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RestartAdminButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

    </Grid>
</Window>
