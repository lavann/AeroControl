<Window x:Class="AeroControl.RiskAcceptanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hardware control notice"
        Width="570"
        Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable Text">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Width="44"
                Height="44"
                HorizontalAlignment="Left"
                Background="{StaticResource WarningBrush}"
                CornerRadius="4">
            <TextBlock Text="!"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="Bahnschrift"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1B211E" />
        </Border>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Text="Hardware control carries risk"
                       FontFamily="Bahnschrift"
                       FontSize="25"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Margin="0,8,0,0"
                       Text="AeroControl is unofficial and is not affiliated with or endorsed by GIGABYTE or AORUS."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="{StaticResource MutedInkBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,22,0,0">
            <TextBlock Margin="0,0,0,12"
                       Text="Firmware writes can change cooling and device behavior. Incorrect settings or unsupported hardware may cause overheating, instability, data loss, hardware damage, or warranty issues."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Margin="0,0,0,12"
                       Text="Use only on hardware that exposes the expected Gigabyte WMI interface. Monitor temperatures, keep automatic mode available, and do not disable firmware safety mechanisms."
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="The software is provided AS IS, without warranty. You accept all responsibility for its use."
                       TextWrapping="Wrap"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource DangerBrush}" />
        </StackPanel>

        <CheckBox x:Name="AcceptCheckBox"
                  Grid.Row="3"
                  Margin="0,18,0,0"
                  VerticalContentAlignment="Center"
                  Checked="AcceptCheckBox_Changed"
                  Unchecked="AcceptCheckBox_Changed">
            <TextBlock Text="I understand the risks and accept responsibility for firmware writes."
                       TextWrapping="Wrap"
                       FontSize="13" />
        </CheckBox>

        <Grid Grid.Row="4" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Margin="0,0,10,0"
                    Padding="18,9"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click" />
            <Button x:Name="AcceptButton"
                    Grid.Column="2"
                    Padding="18,9"
                    Content="Accept and unlock"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsEnabled="False"
                    Click="AcceptButton_Click" />
        </Grid>
    </Grid>
</Window>
